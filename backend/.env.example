# Labelo Backend — fill in after Phase 0 rollup launch + contract deploy

# ── Chain ──────────────────────────────────────────────────────────────────
# JSON-RPC URL from `weave rollup launch`
LABELO_RPC_URL=https://jsonrpc.YOUR-ROLLUP.initia.xyz

# Oracle wallet private key (must match ORACLE_ADDRESS passed to BountyEscrow constructor)
ORACLE_PRIVATE_KEY=0x...

# ── Contracts (deployed addresses) ────────────────────────────────────────
MOCK_USDC_ADDRESS=0x...
BOUNTY_ESCROW_ADDRESS=0x...

# ── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Server ─────────────────────────────────────────────────────────────────
PORT=4000
CORS_ORIGIN=http://localhost:3000
